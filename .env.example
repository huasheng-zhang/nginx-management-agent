# Nginx Agent API 环境变量配置示例
# 复制此文件为 .env 并修改相关配置

# Flask环境
FLASK_ENV=production

# API配置
API_HOST=0.0.0.0
API_PORT=5000

# 安全配置（重要：生产环境必须设置）
# 使用以下命令生成随机Token: openssl rand -hex 32
AUTH_TOKEN=your-secure-random-token-here

# Nginx配置路径
NGINX_CONFIG_PATH=/etc/nginx/nginx.conf
NGINX_BACKUP_DIR=/etc/nginx/backup
NGINX_PID_PATH=/var/run/nginx.pid
NGINX_BINARY=/usr/sbin/nginx
NGINX_LOG_DIR=/var/log/nginx

# 日志配置
LOG_FILE=/var/log/nginx-agent.log
LOG_LEVEL=INFO

# 监控配置
METRICS_UPDATE_INTERVAL=10

# 允许的CORS源（逗号分隔）
ALLOWED_ORIGINS=*
